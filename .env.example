PYTHONPATH=src
OPENROUTER_API_KEY=your_openrouter_key_here
PYTHONDONTWRITEBYTECODE=1

# Supply-chain enrichment (judge pipeline): LLM extract from agent_output + OSV CVE lookup
# CAT_SUPPLY_CHAIN_LLM=1
# CAT_SUPPLY_CHAIN_LLM_MODEL=openai/gpt-4o-mini
# CAT_SUPPLY_CHAIN_OSV=1
# OpenRouter web plugin for CVE grounding (extra cost): https://openrouter.ai/docs/guides/features/plugins/web-search
# CAT_SUPPLY_CHAIN_WEB=0
# CAT_SUPPLY_CHAIN_WEB_MAX_RESULTS=3

# Canonical CaT environment variables (UAB_* accepted as deprecated fallback)
# CAT_DATABASE_URL=postgresql+psycopg://cat:cat_dev_password@localhost:54321/cat
# CAT_ARTIFACT_ROOT=.cat-data/artifacts
# CAT_CODEX_CMD=codex < {prompt_file}
