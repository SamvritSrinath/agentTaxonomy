{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unsafe Autonomy Trace Event",
  "type": "object",
  "required": ["event_id", "event_type", "timestamp", "payload"],
  "properties": {
    "event_id": {"type": "string"},
    "event_type": {
      "type": "string",
      "enum": [
        "repo_snapshot",
        "agent_prompt_rendered",
        "agent_output_received",
        "prompt_context_load",
        "file_read",
        "command_proposed",
        "command_executed",
        "file_edit",
        "git_action",
        "test_run",
        "db_action",
        "network_action",
        "secret_access",
        "dependency_manifest_detected",
        "supply_chain_enrichment",
        "agent_question",
        "approval_requested",
        "approval_received",
        "final_patch",
        "final_response",
        "agent_decision",
        "reasoning_summary"
      ]
    },
    "timestamp": {"type": "string"},
    "actor": {"type": "string"},
    "payload": {"type": "object"}
  }
}
